local accountCreated = "❓ Unknown"
local accountAgeDays = "❓ Unknown"
local avatarUrl = "❓ Unknown"


if r then
    pcall(function()
        local ok, res = pcall(function()
            return r({
                Url = ("https://users.roblox.com/v1/users/%d"):format(e),
                Method = "GET"
            })
        end)
        if ok and res and res.Body then
            local userdata = b:JSONDecode(res.Body)
            if userdata and userdata.created then
                accountCreated = userdata.created 
                
                local success, createdTime = pcall(function()
                    -- parse
                    local y, mo, d_day, hh, mm, ss = accountCreated:match("^(%d+)%-(%d+)%-(%d+)T(%d+):(%d+):(%d+)")
                    if not y then return nil end
                    local created = os.time({
                        year = tonumber(y),
                        month = tonumber(mo),
                        day = tonumber(d_day),
                        hour = tonumber(hh),
                        min = tonumber(mm),
                        sec = tonumber(ss)
                    })
                    return created
                end)
                if success and type(createdTime) == "number" then
                    local now = os.time()
                    local days = math.floor((now - createdTime) / 86400)
                    accountAgeDays = tostring(days) .. " day(s)"
                end
            end
        end
    end)
end

